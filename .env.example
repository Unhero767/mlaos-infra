# Database Configuration
DB_USER=mlaos
DB_PASSWORD=your_secure_password_here
DB_NAME=mlaos_db

# API Configuration
DATABASE_URL=postgresql://mlaos:your_secure_password_here@postgres:5432/mlaos_db

# Server Configuration
PORT=8080
PYTHONUNBUFFERED=1

# Model Configuration
MODEL_VERSION=AURELIA-v2.3

# Feature Extraction
FEATURE_CONFIG_PATH=/app/config/features.yaml

# Pruning Automation
PRUNING_THRESHOLD_DAYS=30

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=production

# Optional: Feature Registry Owner
FEATURE_OWNER_EMAIL=kennydallmier@gmail.com
